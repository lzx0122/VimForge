{
  "name": "vim-forge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "content:validate": "vite-node --script scripts/content-validate.ts",
    "test:e2e": "playwright test",
    "supabase:cli": "npx --no-install supabase@2.79.0",
    "content:export:production": "vite-node --script scripts/content-export-production.ts",
    "content:diff": "vite-node --script scripts/content-diff.ts",
    "content:prepare-release": "vite-node --script scripts/content-prepare-release.ts",
    "content:publish:production": "vite-node --script scripts/content-publish-production.ts"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/legacy-modes": "^6.5.3",
    "@lezer/highlight": "1.2.3",
    "@replit/codemirror-vim": "^6.3.0",
    "@supabase/supabase-js": "^2.109.0",
    "codemirror": "^6.0.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.40",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^9.39.5",
    "eslint-plugin-vue": "^10.9.2",
    "fake-indexeddb": "^6.2.4",
    "globals": "^16.5.0",
    "jiti": "^2.7.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.6",
    "vitest": "^3.2.7",
    "vue-tsc": "^3.3.7"
  }
}
